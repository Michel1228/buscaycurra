# Variables de entorno para BuscayCurra
# Copia este archivo como .env.local y rellena los valores

# ==========================================
# BASE DE DATOS — Supabase
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# PAGOS — Stripe
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# REDIS — Sistema de Caché
# En local: redis://localhost:6379
# En producción (Upstash, Redis Cloud, etc.): redis://user:pass@host:port
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# INTELIGENCIA ARTIFICIAL
# ==========================================

# Groq API (Llama 3.3 — ultrarrápido, gratuito)
# Consíguela en: https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini API (1.5 Flash — contexto largo, gratuito)
# Consíguela en: https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ==========================================
# CONFIGURACIÓN DEL CACHÉ
# ==========================================

# TTL por defecto en segundos (3600 = 1 hora)
CACHE_TTL_DEFAULT=3600

# Activar/desactivar caché de IA (true/false)
AI_CACHE_ENABLED=true

# ==========================================
# ADMINISTRACIÓN
# ==========================================

# Secreto para acceder al panel de admin (/api/cache/stats)
# Genera uno seguro con: openssl rand -hex 32
ADMIN_SECRET=cambia_esto_por_algo_muy_secreto

# ==========================================
# ENTORNO
# ==========================================
NODE_ENV=development
