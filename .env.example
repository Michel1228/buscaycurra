# ═══════════════════════════════════════════════════════════════
# BuscayCurra — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# Copia este archivo a .env.local y rellena los valores:
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════

# ==========================================
# BASE DE DATOS — Supabase
# Obtén estas credenciales en: https://supabase.com/dashboard
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# PAGOS — Stripe
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs de precio de Stripe (crear productos en: https://dashboard.stripe.com/products)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPRESA=price_...

# ==========================================
# REDIS — Sistema de Caché y Colas BullMQ
# En local: usa docker-compose up -d redis
# En producción: usa Redis Cloud (https://redis.com/try-free/)
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# RESEND — Envío de emails
# Obtén tu API key en: https://resend.com/api-keys
# ==========================================
RESEND_API_KEY=
FROM_EMAIL=noreply@buscaycurra.es

# ==========================================
# INTELIGENCIA ARTIFICIAL
# ==========================================

# Groq API (Llama 3.3 — ultrarrápido, gratuito)
# Consíguela en: https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini API (1.5 Flash — contexto largo, gratuito)
# Consíguela en: https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Adzuna API (búsqueda de empleo en España)
# Credenciales en: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# URL del servidor WebSocket de OpenClaw para personalización con IA
OPENCLAW_WS_URL=wss://openclaw.zkjzrt.easypanel.host

# ==========================================
# CONFIGURACIÓN DEL CACHÉ
# ==========================================

# TTL por defecto en segundos (3600 = 1 hora)
CACHE_TTL_DEFAULT=3600

# Activar/desactivar caché de IA (true/false)
AI_CACHE_ENABLED=true

# ==========================================
# WORKER DE BULLMQ
# ==========================================

# Cuántos envíos puede procesar el worker simultáneamente
# Empieza con 1, aumenta según la capacidad del servidor
WORKER_CONCURRENCY=1

# ─── Límites por plan ────────────────────────────────────────
# CVs máximos por día según el plan del usuario
MAX_CVS_PER_DAY_FREE=2
MAX_CVS_PER_DAY_PRO=10

# ==========================================
# ADMINISTRACIÓN
# ==========================================

# Secreto para acceder al panel de admin (/api/cache/stats)
# Genera uno seguro con: openssl rand -hex 32
ADMIN_SECRET=cambia_esto_por_algo_muy_secreto

# ==========================================
# ENTORNO
# ==========================================
NODE_ENV=development
