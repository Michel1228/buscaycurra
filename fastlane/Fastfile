default_platform(:ios)

platform :ios do

  desc "Build and upload to App Store Connect"
  lane :deploy do
    # Autenticación con API key
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:  Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_P8"]),
      in_house:     false,
    )

    # Build del IPA con firma 100% automática
    gym(
      project:                  "ios/App/App.xcodeproj",
      scheme:                   "App",
      configuration:            "Release",
      output_directory:         "/tmp/ipa",
      output_name:              "BuscayCurra.ipa",
      export_method:            "app-store",
      xcargs:                   "DEVELOPMENT_TEAM=P9L962T32A CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates",
      export_options: {
        teamID:       "P9L962T32A",
        signingStyle: "automatic",
      },
    )

    # Subir a App Store Connect
    pilot(
      api_key:            api_key,
      ipa:                "/tmp/ipa/BuscayCurra.ipa",
      skip_waiting_for_build_processing: true,
    )

    UI.success("BuscayCurra subida a TestFlight correctamente")
  end

end
