default_platform(:ios)

platform :ios do

  desc "Build and upload to App Store Connect"
  lane :deploy do
    # Autenticación con API key (sin Apple ID ni contraseña)
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:  Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_P8"]),
      in_house:     false,
    )

    # Revocar certificados viejos para no exceder el límite de Apple (máx 3)
    UI.message("Verificando certificados de distribución...")
    require 'spaceship'
    Spaceship::ConnectAPI.login(api_key)
    certs = Spaceship::ConnectAPI::Certificate.all.select { |c| c.certificate_type == "DISTRIBUTION" }
    UI.message("Certificados de distribución existentes: #{certs.length}/3")
    if certs.length >= 3
      UI.important("Límite alcanzado — revocando los #{certs.length - 2} certificados más antiguos")
      certs.sort_by { |c| c.created_date || Time.now }[0..(certs.length - 3)].each do |c|
        UI.message("Revocando certificado #{c.id} (#{c.name}) creado el #{c.created_date}")
        c.revoke!
      end
      UI.success("Certificados revocados. Quedan 2 slots libres.")
    end

    # Crear/descargar certificado de distribución automáticamente
    cert(
      api_key:     api_key,
      output_path: "/tmp/certs",
    )

    # Crear/descargar provisioning profile automáticamente
    sigh(
      api_key:              api_key,
      app_identifier:       "es.buscaycurra.app",
      output_path:          "/tmp/profiles",
      provisioning_name:    "BuscayCurra Distribution",
      force:                true,
    )

    # Build del IPA
    gym(
      workspace:             "ios/App/App.xcworkspace",
      scheme:                "App",
      configuration:         "Release",
      output_directory:      "/tmp/ipa",
      output_name:           "BuscayCurra.ipa",
      export_method:         "app-store",
      export_options: {
        teamID:                   "P9L962T32A",
        signingStyle:             "manual",
        provisioningProfiles: {
          "es.buscaycurra.app" => "BuscayCurra Distribution",
        },
      },
    )

    # Subir a App Store Connect (TestFlight)
    pilot(
      api_key:            api_key,
      ipa:                "/tmp/ipa/BuscayCurra.ipa",
      skip_waiting_for_build_processing: true,
    )

    UI.success("BuscayCurra subida a TestFlight correctamente")
  end

end
