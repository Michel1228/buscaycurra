default_platform(:ios)

platform :ios do

  desc "Build and upload to App Store Connect"
  lane :deploy do
    # Autenticación con API key
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content:  Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_P8"]),
      in_house:     false,
    )

    # Crear certificado y perfil vía API
    cert(
      api_key:     api_key,
      output_path: "/tmp/certs",
    )

    sigh(
      api_key:              api_key,
      app_identifier:       "es.buscaycurra.app",
      output_path:          "/tmp/profiles",
      provisioning_name:    "BuscayCurra Distribution",
      force:                true,
    )

    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    profile_name = lane_context[SharedValues::SIGH_NAME]
    profile_uuid = lane_context[SharedValues::SIGH_UUID]
    UI.message("Profile: #{profile_name} (#{profile_uuid})")

    # Copiar perfil a ubicación estándar de Xcode
    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profiles_dir)
    FileUtils.cp(profile_path, "#{profiles_dir}/#{profile_uuid}.mobileprovision")

    # Build con firma MANUAL, perfil explícito
    gym(
      project:                  "ios/App/App.xcodeproj",
      scheme:                   "App",
      configuration:            "Release",
      output_directory:         "/tmp/ipa",
      output_name:              "BuscayCurra.ipa",
      export_method:            "app-store",
      xcargs:                   "DEVELOPMENT_TEAM=P9L962T32A PROVISIONING_PROFILE_SPECIFIER='#{profile_name}' CODE_SIGN_STYLE=Manual",
      export_options: {
        teamID:       "P9L962T32A",
        signingStyle: "manual",
        provisioningProfiles: {
          "es.buscaycurra.app" => profile_name
        }
      },
    )

    # Subir a App Store Connect
    pilot(
      api_key:            api_key,
      ipa:                "/tmp/ipa/BuscayCurra.ipa",
      skip_waiting_for_build_processing: true,
    )

    UI.success("BuscayCurra subida a TestFlight correctamente")
  end

end
