generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum JobSector {
  HOSTELERIA
  INDUSTRIA
  OFICINA
  COMERCIO
  SALUD
  EDUCACION
  TECNOLOGIA
  CONSTRUCCION
  TRANSPORTE
  OTRO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cvs           CV[]
  applications  Application[]
  savedJobs     SavedJob[]
}

model CV {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  
  // Datos personales
  fullName        String
  email           String
  phone           String
  city            String
  birthDate       DateTime?
  
  // Foto
  originalPhoto   String?   // ruta foto original
  enhancedPhoto   String?   // ruta foto mejorada por IA
  
  // Sector objetivo
  targetSector    JobSector
  targetPosition  String     // "Camarero", "Operario", etc.
  
  // Contenido generado por IA
  summary         String?    @db.Text // Resumen profesional
  experience      Json?      // Array de experiencias
  education       Json?      // Array de educación
  skills          Json?      // Array de habilidades
  languages       Json?      // Array de idiomas
  
  // Carta de presentación
  coverLetter     String?    @db.Text
  
  // PDF generado
  pdfUrl          String?
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  applications    Application[]
}

model JobListing {
  id            String    @id @default(cuid())
  title         String
  company       String?
  description   String?   @db.Text
  sector        JobSector
  city          String?
  province      String?
  salary        String?
  sourceUrl     String    // URL original del tablón
  sourceName    String    // "SEPE", "Ayuntamiento Madrid", etc.
  contactEmail  String?
  contactPhone  String?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  scrapedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())

  applications  Application[]
  savedJobs     SavedJob[]
}

model Application {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  cvId          String
  cv            CV        @relation(fields: [cvId], references: [id])
  jobId         String?
  job           JobListing? @relation(fields: [jobId], references: [id])
  
  companyName   String
  companyEmail  String?
  sentAt        DateTime  @default(now())
  status        String    @default("sent") // sent, opened, replied, rejected
  coverLetter   String?   @db.Text
  
  createdAt     DateTime  @default(now())
}

model SavedJob {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  jobId     String
  job       JobListing @relation(fields: [jobId], references: [id])
  savedAt   DateTime   @default(now())

  @@unique([userId, jobId])
}
