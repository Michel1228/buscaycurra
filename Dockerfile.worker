FROM node:20-alpine
WORKDIR /app

# Chromium para generar PDFs de CV con Playwright (igual que el container principal)
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    font-noto \
    font-noto-emoji

ENV CHROMIUM_PATH=/usr/bin/chromium-browser

COPY package.json package-lock.json* ./
RUN npm ci --ignore-scripts

COPY . .

CMD ["node_modules/.bin/tsx", "scripts/worker-entrypoint.ts"]
